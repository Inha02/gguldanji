  "normalization_rules": [
    {
      "field": "item_subtype",
      "rules": [
        "'백','가방','팩','보스턴','더플','힙색','웨이스트' 포함 → '가방'",
        "'지갑','월릿','월렛','카드지갑','머니클립','명함지갑' → '지갑'"
      ]
    },
    {
      "field": "bag_style",
      "rules": [
        "'백팩','책가방','배낭' → '백팩'",
        "'크로스','메신저','사코슈','슬링','힙색','웨이스트' → '크로스백'",
        "'토트','쇼퍼','에코백','워크백' → '토트/숄더백'",
        "'클러치','파우치' → '파우치/클러치'"
      ]
    },
    {
      "field": "wallet_style",
      "rules": [
        "'장지갑','롱 월릿','롱월렛' → '장지갑'",
        "'반지갑','중지갑','2단','3단' → '반지갑'",
        "'카드지갑','카드 케이스' → '카드지갑'"
      ]
    },
    {
      "field": "material_main",
      "rules": [
        "'소가죽','천연가죽','양가죽','송아지','카프','엠보','사피아노' → '가죽'",
        "'PU','인조가죽','합성피혁' → '합성가죽'",
        "'캔버스','면','코튼','데님','코듀로이' → '패브릭'",
        "'나일론','폴리','폴리에스터' → '나일론/폴리'"
      ]
    },
    {
      "field": "color_main",
      "rules": [
        "유사 색상 단어는 대표색으로 맵핑 예:'버건디'→'레드','아이보리/크림/베이지' 구분 유지",
        "두 색 이상 표기시 바디 기준 또는 첫 색상 선택"
      ]
    },
    {
      "field": "pattern_print",
      "rules": [
        "브랜드 로고 반복/모노그램/GG/체크 시 '로고패턴'",
        "'퀼팅','뱀피','애니멀','플라워','반다나' 등은 해당 패턴명 저장",
        "언급 없으면 '무지'"
      ]
    },
    {
      "field": "gender_target",
      "rules": [
        "'남성','남자','맨즈' → '남성'",
        "'여성','여자','레이디스' → '여성'",
        "'유아동','키즈','초등','학생' → '아동/주니어'",
        "복수 언급 또는 미기재 → '공용'"
      ]
    },
    {
      "field": "usage_type",
      "rules": [
        "'서류','노트북','비즈니스','브리프' → '비즈니스'",
        "'골프','야구','축구','등산','캠핑','라운딩' → '스포츠'",
        "'여행','캐리어','트렁크' → '여행'",
        "'책가방','학교','신학기' → '스쿨'",
        "'강아지','고양이','펫','반려' → '펫",
        "기타 → '데일리'"
      ]
    },
    {
      "field": "brand",
      "rules": [
        "대소문자/띄어쓰기 정규화 예:'루이 비통'→'루이비통'",
        "명품 카테고리 공백/오타 교정 사전 사용"
      ]
    }
  ],
