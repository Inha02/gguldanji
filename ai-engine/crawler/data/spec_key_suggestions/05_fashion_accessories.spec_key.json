        {
          "field": "bag_style",
          "range_or_vocab": "['백팩','크로스백','토트/숄더백','파우치/클러치','캐리어']"
        },
        {
          "field": "wallet_style",
          "range_or_vocab": "['장지갑','반지갑','카드지갑','머니클립']"
