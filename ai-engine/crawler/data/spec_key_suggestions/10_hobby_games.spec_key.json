  "normalization_rules": [
    {
      "field": "item_type",
      "rules": [
        "‘본체’, ‘세트’+콘솔명 → ‘콘솔’",
        "‘칩/카트리지/디스크’ → ‘게임타이틀’",
        "‘아미보/OST/굿즈’ → ‘굿즈’"
      ]
    },
    {
      "field": "platform",
      "rules": [
        "‘닌텐도 스위치1/2’ → ‘Switch’ or ‘Switch2’",
        "‘플스/플레이스테이션’+숫자 → ‘PS{n}’",
        "‘엑스박스/xbox’ → ‘Xbox’ 계열 코드"
      ]
    },
    {
      "field": "product_form",
      "rules": [
        "‘알칩/칩/디스크/패키지’ → ‘패키지’",
        "‘DL/다운로드/계정/어카운트’ → ‘DL계정’",
        "명시 없고 계정 언급 없으면 ‘패키지’"
      ]
    },
    {
      "field": "condition_grade",
      "rules": [
        "‘미개봉/새상품/S급’ → ‘S’",
        "‘깨끗/사용감 적음/A급’ → ‘A’",
        "‘생활기스/사용감 있음’ → ‘B’",
        "‘기스 많음/플레이용/하자 있음’ → ‘C’",
        "‘고장/부품용’ → ‘D’"
      ]
    },
    {
      "field": "box_included",
      "rules": [
        "‘풀박/박스o/정품 박스’ → true",
        "‘박스없음/케이스없음/알칩’ → false",
        "언급 없으면 null 유지"
      ]
    },
    {
      "field": "region_version",
      "rules": [
        "‘정발/한국어 전용’ → ‘한국정발’",
        "‘일판/일본판’ → ‘일판’",
        "‘북미/US/NA’ → ‘북미판’"
      ]
    },
    {
      "field": "storage_capacity_gb",
      "rules": [
        "‘{n}TB’ → n*1024 GB",
        "복수 용량 표기 시 본체(콘솔) 우선",
        "문자 포함시 숫자만 추출"
      ]
    },
    {
      "field": "bundle_game_count",
      "rules": [
        "‘게임다수/여러개’ → null",
        "‘n개/타이틀 n장’ → n",
        "개별 목록 수를 세어 자동 추정"
      ]
    }
  ],
