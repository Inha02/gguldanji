  "normalization_rules": [
    {
      "field": "item_type",
      "rules": [
        "셔츠/남방/와이셔츠→셔츠",
        "니트/스웨터→니트",
        "집업 가디건/니트집업→집업 가디건",
        "후드집업/후디→후드 집업",
        "맨투맨/스웻셔츠→맨투맨"
      ]
    },
    {
      "field": "gender",
      "rules": [
        "남성/남자→남성",
        "남녀공용/유니섹스→공용",
        "표기없고 카테고리가 남성의류면 남성"
      ]
    },
    {
      "field": "size_tag",
      "rules": [
        "공백 제거 후 저장",
        "KR100/105→100,105로 분리 시 첫 값 우선",
        "L(100)/M(95) 같이 표기시 괄호 안 KR만 저장"
      ]
    },
    {
      "field": "size_estimated_kr",
      "rules": [
        "'95사이즈','남성100정도' 등 숫자 추출",
        "없으면 size_tag에서 90~115 추출",
        "범위표현(100~105)은 큰쪽 기준"
      ]
    },
    {
      "field": "material_main",
      "rules": [
        "울/모 동일 처리→울",
        "앙고라/캐시미어/알파카→해당명 유지",
        "면100/코튼100→면",
        "폴리/폴리에스터→폴리에스터"
      ]
    },
    {
      "field": "season",
      "rules": [
        "여름/린넨/반팔/아이스→여름",
        "기모/두꺼운 니트/패딩→겨울",
        "봄가을/간절기→봄가을",
        "언급없으면 null"
      ]
    },
    {
      "field": "thickness",
      "rules": [
        "경량/얇은/린넨→얇음",
        "기모/두툼/헤비→두꺼움",
        "보통/표기없음→보통"
      ]
    },
    {
      "field": "condition_grade",
      "rules": [
        "새상품/택있음/미사용→N",
        "1~2회/새것수준/A급/9.5/10→A",
        "생활사용감/8~9/10→B",
        "보풀/오염/수선/하자 언급→C"
      ]
    },
    {
      "field": "fabric_pattern",
      "rules": [
        "체크/깅엄/타탄→체크",
        "스트라이프/줄무늬→스트라이프",
        "무늬없음/솔리드→무지"
      ]
    },
    {
      "field": "color_main",
      "rules": [
        "네이비/곤색→네이비",
        "라이트블루/소라→블루",
        "다크그린/카키→그린",
        "베이지/아이보리/크림은 원단 표현 따라 단일값 선택"
      ]
    }
  ],
