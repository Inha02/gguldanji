  "normalization_rules": [
    {
      "field": "storage_capacity",
      "rules": [
        "GB/TB 단위로 통일",
        "예: 256G→256GB",
        "1테라→1TB"
      ]
    },
    {
      "field": "memory_ram",
      "rules": [
        "숫자+GB 형식",
        "예: 램 16→16GB",
        "8기가→8GB"
      ]
    },
    {
      "field": "color",
      "rules": [
        "대표 색상명만 추출",
        "혼합색은 첫 색상 기준",
        "영문 색은 한글 또는 영문 한쪽으로 통일"
      ]
    },
    {
      "field": "condition_grade",
      "rules": [
        "새상품/미개봉/단순개봉→새상품",
        "사용감 적음/거의 새것→중고_S급",
        "생활기스 있음→중고_A급 등 내부 등급 맵"
      ]
    },
    {
      "field": "battery_health",
      "rules": [
        "배터리 성능 n%는 그대로",
        "사이클 n회 별도 숫자 추출",
        "새배터리/교체→replaced 플래그"
      ]
    },
    {
      "field": "device_type",
      "rules": [
        "카테고리+키워드로 매핑",
        "폰/휴대폰/아이폰→스마트폰",
        "북/노트→노트북"
      ]
    },
    {
      "field": "screen_size_inch",
      "rules": [
        "인치/\" 단위 숫자만",
        "cm 표기시 인치 환산은 생략 또는 별도 필드",
        "대략 15.6형 등은 15.6으로"
      ]
    },
    {
      "field": "network_lock_status",
      "rules": [
        "자급제/공기계→언락",
        "선약/약정/선택약정표현만 있고 락 언급 없으면 unknown",
        "해지 완료는 언락으로 간주"
      ]
    },
    {
      "field": "os_version",
      "rules": [
        "iOS/Android/Windows 접두어 유지",
        "버전 숫자만 정규화",
        "예: IOS 18→iOS 18"
      ]
    }
  ],
