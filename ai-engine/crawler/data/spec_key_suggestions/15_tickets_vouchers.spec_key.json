  "normalization_rules": [
    {
      "field": "ticket_type",
      "rules": [
        "기프티콘/모바일상품권/깊콘→'기프티콘'",
        "티켓/관람권/입장권→'티켓'",
        "쿠폰/할인쿠폰→'쿠폰'"
      ]
    },
    {
      "field": "usage_category",
      "rules": [
        "카페/커피/디저트→'카페'",
        "치킨/피자/패스트푸드→'외식'",
        "영화/전시/뮤지컬/콘서트→'공연/문화'",
        "편의점/마트→'소매'"
      ]
    },
    {
      "field": "valid_until_date",
      "rules": [
        "'YYYY.MM.DD','YY.MM.DD'→'YYYY-MM-DD'",
        "'오늘까지','내일','모레' 현재일 기준 계산",
        "'2월말까지'→해당월 말일"
      ]
    },
    {
      "field": "face_value_krw",
      "rules": [
        "'3만원/30,000'→30000",
        "'5만권/5만원권'→50000"
      ]
    },
    {
      "field": "discount_price_krw",
      "rules": [
        "쉼표 제거 후 정수",
        "'무료/나눔'→0"
      ]
    },
    {
      "field": "event_date",
      "rules": [
        "텍스트 날짜 '2월 6일'→'YYYY-02-06'",
        "요일/회차 제거"
      ]
    },
    {
      "field": "seat_block",
      "rules": [
        "'1층 8구역'→'1층-8구역'",
        "'B구역','S2구역' 그대로 유지"
      ]
    },
    {
      "field": "quantity",
      "rules": [
        "없으면 1 기본",
        "'N장 남음','N매' 숫자 추출"
      ]
    },
    {
      "field": "merchant_name",
      "rules": [
        "브랜드 철자 통일(파리바게트/파리바게뜨→'파리바게뜨')"
      ]
    },
    {
      "field": "days_to_expiry",
      "rules": [
        "valid_until_date-오늘일수",
        "음수면 0 또는 만료표시"
      ]
    }
  ],
