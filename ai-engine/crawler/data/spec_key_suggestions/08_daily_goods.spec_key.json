  "normalization_rules": [
    {
      "field": "dimensions_cm",
      "rules": [
        "모든 수치는 cm로 환산",
        "형식 ‘가로Wx깊이Dx높이H’ 통일",
        "mm 표기는 ÷10 후 반올림"
      ]
    },
    {
      "field": "capacity_volume_l",
      "rules": [
        "ml는 ÷1000해 L로 저장",
        "리터 기호(L,l)는 제거",
        "범위 표기는 최대값 기준"
      ]
    },
    {
      "field": "main_material",
      "rules": [
        "‘원목/집성목’→‘원목’",
        "‘철/스틸/메탈’→‘철제’",
        "‘플라/PP/PE’→‘플라스틱’"
      ]
    },
    {
      "field": "item_type",
      "rules": [
        "자유입력 원문 유지",
        "광고 표현 제거(‘최저가’ 등)",
        "복합명은 대표 품목 1개 선택"
      ]
    },
    {
      "field": "use_space",
      "rules": [
        "‘침실/안방’→‘침실’",
        "‘현관/신발장’→‘현관’",
        "불명확시 ‘기타’"
      ]
    },
    {
      "field": "door_type",
      "rules": [
        "‘미닫이’→‘슬라이딩’",
        "문 언급 없고 완전 오픈형이면 ‘도어없음’",
        "커튼식은 ‘기타’"
      ]
    },
    {
      "field": "mobility",
      "rules": [
        "‘바퀴/트롤리/이동식’ 포함시 ‘바퀴있음’",
        "벽걸이·붙박이는 ‘고정형’",
        "기타는 기본 ‘고정형’"
      ]
    },
    {
      "field": "brand",
      "rules": [
        "공백·대소문자 정규화",
        "못 찾으면 ‘기타’",
        "쇼핑몰명(쿠팡 등)은 제외"
      ]
    },
    {
      "field": "shelf_drawer_count",
      "rules": [
        "숫자+단위로 축약(‘선반4’ 등)",
        "여러 값일 땐 ‘선반4/서랍3’",
        "불명확하면 빈값"
      ]
    },
    {
      "field": "set_components",
      "rules": [
        "구성품은 50자 이내 요약",
        "동일 품목 다수는 ‘xN’ 표기",
        "사은품·약품 자잘한 건 생략"
      ]
    }
  ],
