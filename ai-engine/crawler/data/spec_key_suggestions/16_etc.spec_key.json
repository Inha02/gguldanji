  "normalization_rules": [
    {
      "field": "condition_grade",
      "rules": [
        "'미사용','새상품','신품급' -> '새상품'",
        "'1~2회','거의 새것' -> '중고 S급'",
        "'사용감 있음','흠 있음' -> '중고 A/B급'"
      ]
    },
    {
      "field": "set_or_single",
      "rules": [
        "'일괄','풀세트','세트' -> '세트'",
        "구성품 1개만 언급 -> '단품'"
      ]
    },
    {
      "field": "size_main",
      "rules": [
        "가로x세로x높이 공백 제거 '×' 통일",
        "cm, m, 인치 단위 그대로 보존",
        "여러 사이즈 중 대표 본체 기준 선택"
      ]
    },
    {
      "field": "usage_count",
      "rules": [
        "'미사용','테스트만' -> '미사용'",
        "'N번','N회'만 추출",
        "'몇번 안씀','5회 미만' 등은 그대로 문자열 유지"
      ]
    },
    {
      "field": "shipping_fee_policy",
      "rules": [
        "'배송비 포함','택포' -> '포함'",
        "'배송비 별도','착불' -> '별도'",
        "직거래만 언급 시 -> '직거래 전용'"
      ]
    },
    {
      "field": "transaction_method",
      "rules": [
        "'직거래' 포함 -> '직거래 가능'",
        "'택배거래' 포함 -> '택배 가능'",
        "둘 다 있으면 '직거래+택배'"
      ]
    },
    {
      "field": "use_season",
      "rules": [
        "'동계','겨울' -> '동계'",
        "'사계절','4계절' -> '사계절'",
        "'하계','여름' -> '하계'"
      ]
    },
    {
      "field": "power_source",
      "rules": [
        "'부탄','가스' -> '가스'",
        "'등유','기름' -> '등유'",
        "'USB','충전식','배터리' -> '전기/배터리'"
      ]
    },
    {
      "field": "capacity_volume",
      "rules": [
        "L, 리터 단위 숫자만 추출",
        "쿼트(QT)는 텍스트 그대로 유지",
        "쿨러/보냉 용기 아용일 때만 세팅"
      ]
    },
    {
      "field": "location_hint",
      "rules": [
        "구/동/역 이름만 추출",
        "상세 주소·호수는 제거",
        "여러 위치면 우선 거래 희망지 1곳"
      ]
    }
  ],
