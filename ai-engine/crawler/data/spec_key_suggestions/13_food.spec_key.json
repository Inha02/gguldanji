  "normalization_rules": [
    {
      "field": "expiry_date",
      "rules": [
        "yy.mm.dd→20yy-mm-dd",
        "‘~까지’·‘유통/소비기한’ 제거",
        "연·월만 있으면 말일로 보정"
      ]
    },
    {
      "field": "net_weight_g",
      "rules": [
        "‘kg’×1000 변환",
        "여러 ‘○g×n’은 곱 후 합산",
        "범위 표기는 큰값 사용"
      ]
    },
    {
      "field": "unit_count",
      "rules": [
        "‘x/×/*’ 뒤 숫자 추출",
        "‘포/정/캔/병/개입’ 앞 숫자",
        "‘한박스 30포’는 30"
      ]
    },
    {
      "field": "form",
      "rules": [
        "‘stick/스틱’→‘스틱’",
        "‘홀빈/원두’→‘홀빈’",
        "‘드립백/티백’ 각각 통일"
      ]
    },
    {
      "field": "origin_country",
      "rules": [
        "‘국내산/국산’→‘국산’",
        "영문국가명은 한국어 통일",
        "복수국가는 ‘혼합’"
      ]
    },
    {
      "field": "brand",
      "rules": [
        "㈜ 등 법인표시 제거",
        "쇼핑몰명(쿠팡 등) 제외",
        "선두 1~3어만 사용"
      ]
    },
    {
      "field": "product_name",
      "rules": [
        "이모지·광고문구 제거",
        "‘무료배송/선물세트’ 등 삭제",
        "브랜드 중복 시 1회만"
      ]
    },
    {
      "field": "food_subtype",
      "rules": [
        "홍삼·인삼 포함시 ‘홍삼건강식품’",
        "홀빈/분쇄/드립백+커피시 ‘커피·원두’",
        "RTD캔/페트는 ‘음료·RTD’"
      ]
    }
  ],
