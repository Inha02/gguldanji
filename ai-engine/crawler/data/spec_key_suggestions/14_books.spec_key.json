  "normalization_rules": [
    {
      "field": "condition_grade",
      "rules": [
        "\"새책\",\"미사용\",\"미개봉\"→새책",
        "필기/사용감 언급시 labels 새상품여도 중고 우선",
        "\"커버만 개봉\" 등은 새책-근접 태그로 메모 가능"
      ]
    },
    {
      "field": "exam_stage",
      "rules": [
        "\"1차\",\"2차\" 그대로 저장",
        "\"1,2차\",\"동차\"→\"1+2차\"",
        "LC/RC/스피킹만 언급시 stage는 빈값, subject_or_part에만 저장"
      ]
    },
    {
      "field": "subject_or_part",
      "rules": [
        "LC/리스닝/듣기→\"LC\"",
        "RC/리딩/읽기→\"RC\"",
        "여러 과목 나열시 쉼표로 구분해 단일 문자열로 저장"
      ]
    },
    {
      "field": "publisher_brand",
      "rules": [
        "해커스어학원/해커스공인중개사→\"해커스\"",
        "에듀윌 토익/에듀윌 공인중개사→\"에듀윌\"",
        "YBM/ETS YBM→\"YBM\""
      ]
    },
    {
      "field": "volume_type",
      "rules": [
        "\"기본서\" 그대로",
        "기출/회차별/단원별 기출→\"기출문제집\"",
        "\"실전1000제\",\"모의고사\"→\"모의고사\"",
        "\"핵심요약\",\"필수서\",\"합격서\"→\"요약/핵심\"",
        "보카/VOCA→\"보카\"",
        "인강/강의권/패스/회원권→\"인강/패스\""
      ]
    },
    {
      "field": "book_type",
      "rules": [
        "카테고리 학습/교육이면 기본 \"수험서\"",
        "국어/외국어+토익/토플/텝스면 \"어학서\" 우선",
        "티켓/쿠폰류는 \"수험부가서비스\" 등 별도 태그 가능"
      ]
    },
    {
      "field": "edition_or_target_year",
      "rules": [
        "여러 연도 표기시 \"~년 대비\" 등 최신 연도",
        "\"29회\" 등 회차만 있으면 빈값 유지",
        "연도 미표시시 추론 금지"
      ]
    },
    {
      "field": "set_included_count",
      "rules": [
        "\"전2권\",\"2권\"→2",
        "\"풀세트\",\"전권\" 등 수 미표기면 0 또는 NULL",
        "여러 패키지 합산 설명은 전체 권수로 추정 가능시만 채움"
      ]
    },
    {
      "field": "series_name",
      "rules": [
        "Vol./시즌/기출문제집n 등 그대로 축약 저장",
        "불필요한 수식어(베스트셀러, 최신판 등) 제거"
      ]
    }
  ],
