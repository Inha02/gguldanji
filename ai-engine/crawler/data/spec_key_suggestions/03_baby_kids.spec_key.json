  "normalization_rules": [
    {
      "field": "product_type",
      "rules": [
        "유모차/웨건/디럭스/휴대용 표현을 소분류+stroller 로 매핑",
        "아기띠/힙시트/포대기/슬링은 baby_carrier 로 통일"
      ]
    },
    {
      "field": "condition_grade",
      "rules": [
        "\"미개봉, 새상품, S급\"→\"S급\"",
        "\"사용감 있음, 생활기스\"→\"보통\" 등 3~4단계로 묶기"
      ]
    },
    {
      "field": "purchase_time",
      "rules": [
        "연·월만 추출해 \"YYYY-MM\" 형식으로",
        "\"몇년식\"은 해당 연도로 매핑"
      ]
    },
    {
      "field": "usage_period",
      "rules": [
        "개월/년/회 표현을 그대로 짧게 보존",
        "불명확하면 빈값 유지, 추정치 생성 금지"
      ]
    },
    {
      "field": "original_price",
      "rules": [
        "\"만\" 단위는 숫자로 변환(80만→800000)",
        "배송비·악세사리 포함 총액은 그대로 보존"
      ]
    },
    {
      "field": "color",
      "rules": [
        "다중 색상은 대표색 한 개만 우선",
        "영문 컬러는 한글 컬러명 병기 없이 원문 유지"
      ]
    },
    {
      "field": "weight_limit",
      "rules": [
        "kg 단위 숫자만 저장",
        "범위 기재 시 최대값 기준으로 기록"
      ]
    },
    {
      "field": "size_or_range",
      "rules": [
        "의류는 숫자+호/개월만 남김",
        "알파벳/숫자 조합 사이즈는 원문 유지"
      ]
    },
    {
      "field": "usage_stage",
      "rules": [
        "\"신생아~36개월\"은 범위 그대로",
        "개월 단위만 주어진 경우 신생아 여부(0개월 포함)만 판단"
      ]
    },
    {
      "field": "included_accessories",
      "rules": [
        "동일 액세서리 여러 개는 종류별로만 나열",
        "브랜드 불명 악세사리는 기능 위주로 요약"
      ]
    }
  ],
