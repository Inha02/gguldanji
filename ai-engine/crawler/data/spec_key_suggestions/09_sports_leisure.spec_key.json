  "normalization_rules": [
    {
      "field": "usage_level",
      "rules": [
        "‘미개봉/새제품/신품급’→‘거의사용안함’",
        "‘몇번/두세번 탔어요’→‘사용적음’",
        "‘자주/매일/헬스장용’→‘사용많음’"
      ]
    },
    {
      "field": "condition_grade",
      "rules": [
        "설명에 ‘하자없음/최상/새것같음’→‘A’",
        "‘생활기스 조금’→‘B’",
        "‘기스많음/교체필요/하자있음’→‘C’"
      ]
    },
    {
      "field": "trade_type",
      "rules": [
        "‘직거래만’→‘직거래’",
        "‘택배 가능/화물’ 포함→‘택배’ 추가",
        "둘 다 언급→‘직거래+택배’"
      ]
    },
    {
      "field": "electric_flag",
      "rules": [
        "제목/카테고리 ‘전기/전동/자토바이’ 포함→true",
        "실내자전거·헬스기구는 모터보조 없으면 false",
        "언급없으면 null 유지"
      ]
    },
    {
      "field": "sport_category",
      "rules": [
        "자전거·전기자전거·실내사이클→‘사이클’",
        "골프채·파크골프·그라운드골프→‘골프’",
        "기타 헬스기구→‘피트니스’"
      ]
    },
    {
      "field": "wheel_size_inch",
      "rules": [
        "‘27.5’ ‘29인치’ 등 숫자 추출",
        "700C는 28로 매핑",
        "16/20인치 미니벨로는 그대로 정수 저장"
      ]
    },
    {
      "field": "shaft_flex",
      "rules": [
        "‘L/LL’ 유지",
        "‘R1/SR’→각각 그대로",
        "‘R대’→‘R’",
        "없으면 null"
      ]
    },
    {
      "field": "purchase_year",
      "rules": [
        "‘2024년식/24년식’→2024",
        "‘25년 7월 구매’→2025",
        "연도 범위 1990~올해만 허용"
      ]
    },
    {
      "field": "gender_target",
      "rules": [
        "‘여성용/레이디’→‘여성용’",
        "‘남성용/맨즈’→‘남성용’",
        "미표기시 null"
      ]
    },
    {
      "field": "handedness",
      "rules": [
        "‘좌타/왼손’→‘좌타’",
        "그 외 명시 없으면 null 유지"
      ]
    }
  ],
