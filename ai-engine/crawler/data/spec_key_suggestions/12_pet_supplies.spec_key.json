  "normalization_rules": [
    {
      "field": "species",
      "rules": [
        "'고양이','냥','묘' → '고양이'",
        "'강아지','견','멍' → '강아지'",
        "복수종 언급시 주 사용 종 하나만"
      ]
    },
    {
      "field": "main_item_type",
      "rules": [
        "'캣폴','캣워크' 포함 → '캣타워/캣폴'",
        "'카라','목걸이'(펫) → '목줄/카라'",
        "'리드줄','자동줄' → '리드줄/자동줄'"
      ]
    },
    {
      "field": "dimensions_cm",
      "rules": [
        "공백·단위 통일: '40 x40x 85'→'40x40x85cm'",
        "가로/세로/높이 순으로 정렬",
        "단위 누락시 'cm' 추가"
      ]
    },
    {
      "field": "height_cm",
      "rules": [
        "'1m70','1.7m' → 170",
        "'높이150 정도' → 150",
        "범위표현시 중간값 사용 금지, 미입력"
      ]
    },
    {
      "field": "levels_count",
      "rules": [
        "'3단','3층' → 3",
        "'5~6단' 등 범위는 null",
        "명시 없으면 추정하지 않음"
      ]
    },
    {
      "field": "size_label",
      "rules": [
        "'엑스스몰'→'XS' 등 영문축약",
        "'소형','중형','대형'은 그대로 저장",
        "여러 사이즈 묶음시 '혼합'"
      ]
    },
    {
      "field": "material_main",
      "rules": [
        "복합재는 비율 큰 것 한 개만",
        "'집성목','자작나무' 등은 '원목'으로 상위 그룹 가능",
        "'패브릭','천','카페트' 등은 '패브릭'"
      ]
    },
    {
      "field": "color_main",
      "rules": [
        "다색 제품은 주조색 1개",
        "수식어 제거: '진한 브라운'→'브라운'",
        "영문색명은 한글 기본색으로 매핑"
      ]
    },
    {
      "field": "brand",
      "rules": [
        "링크 도메인 브랜드명 제거(예: '.coupang.com')",
        "대소문자 통일, 양끝 공백 제거",
        "쇼핑몰명/플랫폼명 제외"
      ]
    }
  ],
