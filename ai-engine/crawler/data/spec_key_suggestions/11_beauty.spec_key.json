  "normalization_rules": [
    {
      "field": "item_type",
      "rules": [
        "‘오드퍼퓸/퍼퓸/EDP’→향수",
        "‘오드뚜왈렛/EDT/코롱’→향수",
        "‘섬유향수/드레스퍼퓸’→섬유향수"
      ]
    },
    {
      "field": "fragrance_type",
      "rules": [
        "‘오드 퍼퓸/퍼퓸’→EDP",
        "‘오드 뚜왈렛’→EDT",
        "미기재 시 빈값 유지"
      ]
    },
    {
      "field": "capacity_ml",
      "rules": [
        "‘mL/ml/ML’ 제거 후 숫자",
        "‘1.7ml x 5개’→합산 또는 per-piece 분리",
        "범위 표기는 최빈값 사용"
      ]
    },
    {
      "field": "condition",
      "rules": [
        "‘미개봉/새거/풀박’→새상품",
        "‘테스터/시향/몇 번 사용’→중고",
        "‘거의 새것’→중고"
      ]
    },
    {
      "field": "remaining_amount_ratio",
      "rules": [
        "‘풀/거의 새것/1~3회’→90~100",
        "‘반 정도’→50",
        "사진선 언급 시 대략 비율로 매핑"
      ]
    },
    {
      "field": "power_watt",
      "rules": [
        "‘W/w’ 제거 후 숫자",
        "‘1600-1800W’→1800",
        "미기재 시 모델 스펙 사전 활용"
      ]
    },
    {
      "field": "release_year",
      "rules": [
        "‘20년·2020년 구매’→2020",
        "‘구매한지 한달’→현재 기준 연도",
        "연도 범위는 최초 연도 사용"
      ]
    },
    {
      "field": "target_user",
      "rules": [
        "‘맨/옴므/남자’→남성용",
        "‘우먼/여성’→여성용",
        "‘유니섹스/남녀공용’→공용"
      ]
    },
    {
      "field": "piece_count",
      "rules": [
        "‘일괄/세트/트리오’ 언급 없고 단품이면 1",
        "‘n종/n개’ 숫자 추출",
        "범위 표기는 최대값 사용"
      ]
    },
    {
      "field": "model_id",
      "rules": [
        "영문+숫자 조합만 추출",
        "색상코드·세트명 제외",
        "공백은 하이픈으로 통일"
      ]
    }
  ],
