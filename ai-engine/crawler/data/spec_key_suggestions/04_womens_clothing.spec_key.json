  "normalization_rules": [
    {
      "field": "official_size",
      "rules": [
        "문자+숫자 분리 없이 원문 유지 예: \"82\"",
        "KR·US혼재시 원문 우선, 필요시 별도 매핑",
        "\"프리, F\"는 \"FREE\"로 통일"
      ]
    },
    {
      "field": "fit_range_kr",
      "rules": [
        "\"44~날씬55\"→\"44~55\"",
        "\"55까지\"→\"~55\"",
        "키/몸무게 언급은 별도 메모, 필드엔 사이즈표현만"
      ]
    },
    {
      "field": "length_type",
      "rules": [
        "총장≥110cm는 \"롱\"",
        "총장 90~109cm는 \"미디\"",
        "총장<90cm는 \"숏\"으로 기본 매핑"
      ]
    },
    {
      "field": "material_main",
      "rules": [
        "혼용률 있으면 비율 포함 그대로",
        "여러 줄 중 겉감 기준 사용",
        "없으면 대표 키워드만 예: \"니트\", \"트위드\""
      ]
    },
    {
      "field": "season",
      "rules": [
        "\"간절기\"→\"봄가을\"",
        "\"한여름 제외\" 등은 주 사용 계절 기준",
        "여러 계절 언급시 가장 긴 기간 택1"
      ]
    },
    {
      "field": "outer_fill",
      "rules": [
        "\"덕다운\"→\"구스다운\"과 구분 유지",
        "비율은 괄호로 예:\"구스다운(솜털80/깃털20)\"",
        "프리마로프트 등 합성은 그대로 표기"
      ]
    },
    {
      "field": "total_length_cm",
      "rules": [
        "\"총장 약 79~80\"→평균값",
        "단위 없는 두세자리수는 cm로 간주",
        "복수 실측시 메인외투 기준 사용"
      ]
    },
    {
      "field": "bust_width_cm",
      "rules": [
        "\"가슴반품\"=가슴단면으로 사용",
        "범위값은 평균 사용",
        "단위 생략시 cm로 처리"
      ]
    },
    {
      "field": "lining",
      "rules": [
        "\"누빔\" 있는 경우 \"있음\"",
        "여름원단·셔츠형 코트 등은 \"없음\"",
        "명시 없으면 추론하지 않고 빈값"
      ]
    },
    {
      "field": "brand",
      "rules": [
        "대문자/소문자 혼합은 원브랜드 표기대로",
        "쇼핑몰명과 브랜드명 혼재시 실제 라벨 우선"
      ]
    }
  ],
